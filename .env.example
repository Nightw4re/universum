# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# Absolute path to your Minecraft instance folder.
# Default (if not set): <repo>/../../curseforge/minecraft/Instances/Universum
# GAME_INSTANCE=C:/Users/you/curseforge/minecraft/Instances/Universum

# Absolute path to the server-only mods instance (used by build:server).
# Default (if not set): <repo>/../../curseforge/minecraft/Instances/Universum-server
# SERVER_INSTANCE=C:/Users/you/curseforge/minecraft/Instances/Universum-server

# CurseForge API credentials — required only for `npm run upload`
# Generate at: https://console.curseforge.com/#/api-keys
# CURSEFORGE_API_TOKEN=your-token-here
# CURSEFORGE_PROJECT_ID=your-project-id-here
