	quest.5A01000000000020.quest_subtitle: "Obtain Bronze Macerator."
	quest.5A01000000000030.quest_subtitle: "Build the steam blast furnace line and secure enough fire clay to support it."
	quest.5A01B00000000010.quest_subtitle: "Build the first water pump setup. Use distilled water when you need stronger output or cleaner processing."
	quest.5A01B00000000020.quest_subtitle: "Set up the Bronze Mixer and Compressor to start real steam-era processing."
	quest.5A01B00000000030.quest_subtitle: "Collect the bronze hatches needed to move items and fluids through your early factory."
	quest.5A01B00000000040.quest_subtitle: "Obtain Steel Upgrade and Steel Machine Casing."
	quest.5A01B00000000050.quest_subtitle: "Obtain Large Steam Boiler."
	quest.5A01B00000000060.quest_subtitle: "Obtain Coke Oven and Bricks."
	quest.5A01B00000000070.quest_subtitle: "Upgrade your mining tools from bronze into steel for faster resource gathering."
	quest.5A01B00000000080.quest_subtitle: "Obtain Steam Quarry."
	quest.5A02000000000010.quest_subtitle: "Build the air compressor, the heart of PneumaticCraft progression."
	quest.5A02000000000020.quest_subtitle: "Assemble the pressure chamber parts needed for your first automated processing room."
	quest.5A02000000000030.quest_subtitle: "Craft the printed circuit board that bridges into mid-game automation."
	quest.5A020CAB439C824C.quest_desc: [
		"You can see attributes in bees, that can be enhanced by breeding or gene mutations to work during rain, and night, collect more, have more health, or even be passive so will attack nobody even if attacked."
		""
		"&lWater Bee&r, &lObsidian&r, and &lKamikazBee&r - have interesting an attribute, check it out."
	]
	quest.5A02B00000000010.quest_subtitle: "Produce compressed iron and begin the pressure-tech path."
	quest.5A02B00000000020.quest_subtitle: "Set up pressure tubes so air can move through the factory safely."
	quest.5A02B00000000030.quest_subtitle: "Create a charging point for tools, armor, and pressure-powered gear."
	quest.5A02B00000000040.quest_subtitle: "Secure oil as the next major resource for pneumatic production."
	quest.5A02B00000000050.quest_subtitle: "Turn crude oil into useful fuel and unlock the refinery chain."
	quest.5A02B00000000060.quest_subtitle: "Refine plastic, a key material for advanced PneumaticCraft parts."
	quest.5A02B00000000080.quest_subtitle: "Prepare the etching line used for advanced circuit work."
	quest.5A02B00000000090.quest_subtitle: "Build the UV light box used to cure and process sensitive materials."
	quest.5A02B000000000A0.quest_subtitle: "Set up the assembly line components that automate high-precision work."
	quest.5A02B000000000B0.quest_subtitle: "Finish the pressure-tech milestone and unlock the next machine tier."
	quest.5A02B000000000C0.quest_subtitle: "Upgrade to advanced pressure tubes for higher-capacity routing."
	quest.5A02B000000000D0.quest_subtitle: "Build the advanced compressor to support the next stage of PneumaticCraft."
	quest.5A02B000000000E0.quest_subtitle: "Assemble the minigun to turn pneumatic pressure into firepower."
	quest.5A02B000000000F0.quest_subtitle: "Deploy the sentry turret for base defense and automation support."
	quest.5A02B00000000100.quest_subtitle: "Create the aerial interface to connect drones and remote control systems."
	quest.5A03000000000010.quest_subtitle: "Craft the Basic Machine Hull. This now gates the LV age without requiring Naquadah."
	quest.5A03000000000030.quest_subtitle: "Obtain Metallurgic Infuser."
	quest.5A03000000000040.quest_subtitle: "Obtain LV Steam Turbine."
	quest.5A03B00000000010.quest_subtitle: "Assemble the first electric processing trio. These machines unlock efficient bulk production."
	quest.5A03B00000000020.quest_subtitle: "Obtain Osmium."
	quest.5A03B00000000030.quest_subtitle: "Build the first Mekanism transport pieces. The last missing item is the Basic Logistical Transporter."
	quest.5A03B00000000040.quest_subtitle: "Add bulk ore processing and material enrichment to your LV setup."
	quest.5A03B00000000060.quest_subtitle: "Set up the LV chemical line. These two machines handle separation and fluid processing."
	quest.5A03B00000000070.quest_subtitle: "Unlock the handling tools for item compression, unpacking, and magnetized processing."
	quest.5A03B00000000090.quest_subtitle: "Pick up the core Mekanism upgrades for speed, power use, and filtering."
	quest.5A04000000000001.quest_desc: ["Craft the first photovoltaic cell used by the LV solar panel. Keep the machine setup simple and consistent."]
	quest.5A04000000000001.quest_subtitle: "Craft the first LV Photovoltaic Cell. Use it as a stepping stone for the solar panel."
	quest.5A04000000000001.title: "LV Photovoltaic Cell I"
	quest.5A04000000000002.quest_desc: ["Repeat the photovoltaic cell craft. This is the second step toward the LV solar panel."]
	quest.5A04000000000002.quest_subtitle: "Craft the second LV Photovoltaic Cell. Keep the same setup and repeat the process."
	quest.5A04000000000002.title: "LV Photovoltaic Cell II"
	quest.5A04000000000003.quest_desc: ["Craft the final photovoltaic cell. Once you have all three, the solar panel chain is complete."]
	quest.5A04000000000003.quest_subtitle: "Craft the third LV Photovoltaic Cell. This completes the solar panel chain requirement."
	quest.5A04000000000003.title: "LV Photovoltaic Cell III"
	quest.5A04000000000005.quest_desc: ["Place it in direct sunlight to generate LV power. It needs daylight and an unobstructed sky."]
	quest.5A04000000000005.title: "LV Solar Panel"
	quest.5A04000000000006.quest_desc: ["An upgraded solar panel for larger and more stable power networks."]
	quest.5A04000000000006.title: "MV Solar Panel"
	quest.5A04000000000007.quest_desc: ["A high-tier solar panel for the final stretch of your electric grid."]
	quest.5A04000000000007.title: "HV Solar Panel"
	quest.5A04000000000010.quest_subtitle: "The advanced hull unlocks MV machines and more complex material processing."
	quest.5A04000000000020.quest_subtitle: "The electric blast furnace handles alloys unavailable to the steam version."
	quest.5A04000000000030.quest_subtitle: "Molecular assembler - AE2 autocrafting with no delivery limits."
	quest.5A04000000000040.quest_subtitle: "MV infrastructure complete. HV tier and SGJourney dimensions are now within reach."
	quest.5A05000000000010.quest_subtitle: "Obtain Turbo Machine Hull."
	quest.5A05000000000020.quest_subtitle: "5 000 000 FE na mezihvězdné spojení. HV generátory jsou nutností."
	quest.5A05000000000030.quest_subtitle: "Reach Netu, the volcanic dimension that feeds the next industrial tier."
	quest.5A05000000000040.quest_subtitle: "Refine more Bismuth Dust to keep the industrial chain moving."
	quest.5A05B00000000010.quest_subtitle: "Obtain MV Steam Turbine, MV Energy Input Hatch, and LV MV Transformer."
	quest.5A05B00000000020.quest_subtitle: "Obtain Distillation Tower."
	quest.5A05B00000000030.quest_subtitle: "Obtain Oil Drilling Rig."
	quest.5A05B00000000040.quest_subtitle: "Obtain Vacuum Freezer."
	quest.5A05B00000000070.quest_subtitle: "Collect raw Bismuth from Netu to bootstrap the next material chain."
	quest.5A05B00000000080.quest_subtitle: "Refine Bismuth into usable ingots and dust for downstream processing."
	quest.5A05B00000000090.quest_subtitle: "Upgrade your drills for late-game mining and tougher ore veins."
	quest.5A06000000000010.quest_subtitle: "Obtain Highly Advanced Machine Hull."
	quest.5A06000000000020.quest_subtitle: "Secure Naquadria, the volatile resource that powers EV-era systems."
	quest.5A06000000000030.quest_subtitle: "Craft the Mekanism module base needed for advanced armor upgrades."
	quest.5A06000000000040.quest_subtitle: "Assemble the first Mekasuit piece and open the late-game armor path."
	quest.5A06B00000000010.quest_subtitle: "Travel to Oannes, the ocean world where Naquadria becomes available."
	quest.5A06B00000000050.quest_subtitle: "Build the module energy unit that powers the next armor upgrade step."
	quest.5A07000000000010.quest_subtitle: "Obtain Quantum Machine Hull."
	quest.5A07000000000020.quest_subtitle: "Reach Niflheim, the frozen dimension that supplies Trinium."
	quest.5A07000000000030.quest_subtitle: "Refine Trinium into ingots so the final tech tier can progress."
	quest.5A07000000000040.quest_subtitle: "Finish the remaining Mekasuit armor pieces for the final protection tier."
	quest.5A07000000000050.quest_subtitle: "Build the superconductor storage unit to support ultra-high power systems."
	quest.5A07000000000060.quest_subtitle: "Unlock the Replicator, the last major machine in the progression line."
	quest.5A07B00000000010.quest_subtitle: "Gather the coils that bridge the final reactor and processor tiers."
	quest.5A07B00000000020.quest_subtitle: "Obtain Implosion Compressor."
	quest.5A07B00000000030.quest_subtitle: "Compress matter into a Singularity for the top-end MI chain."
	quest.5A07B00000000040.quest_subtitle: "Assemble the core quantum components needed for the final machines."
	quest.5A07B00000000050.quest_subtitle: "Craft the gravity module needed for endgame mobility and control."
	quest.5A0E000000000010.quest_subtitle: "Obtain Superconductor Storage Unit."
	quest.5A0E000000000020.quest_subtitle: "Obtain Quantum Barrel."
	quest.5A2581CBAB21D071.quest_desc: [
		"This useful block can be used to store and redistrubute energy. It both accepts and automatically pushes energy to adjacent energy storages."
		""
		"Right clicking with an item that stores energy places the item onto the Energizer to charge it."
	]
	quest.5A2581CBAB21D071.quest_subtitle: "Electrifying Elements"
