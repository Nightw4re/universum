	quest.7E7F74710F4BF164.title: "The Butcher's Knife"
	quest.7EA70677B5820EB0.quest_desc: ["Finish a basic work outfit. This is not battle gear; it is a practical uniform for messy work around the butcher area."]
	quest.7EA70677B5820EB0.title: "Work Clothes, Not Armor"
	quest.7F2A11C4D6B8E901.quest_desc: ["Gather the clues needed to solve the final symbol. Bring a spyglass, a book and quill, and a digital circuit to complete the research."]
	quest.7F2A11C4D6B8E901.quest_subtitle: "Obtain Spyglass, Writable Book, and Digital Circuit."
	quest.7F2A11C4D6B8E901.title: "Finding the 7th Chevron"
	quest.7FA54F2D5D3E5D7D.quest_desc: ["Traders offer you a way to improve your beggings, you can trade Emeralds and a Bee Cage for Strudy Bee Cage (not destroyed on release)."]
	quest.7FA54F2D5D3E5D7D.title: "Villager"
	quest.7FE5D97F399B576E.quest_desc: ["You now know the full basic chain: milk, tools, slaughter, hanging, cutting, rendering, grinding, cooking, and work clothing."]
	quest.7FE5D97F399B576E.title: "Nothing Goes to Waste"
	quest.A1B2C3D4E5F60001.quest_desc: ["With Pure Naquadah and a Classic Stargate operational, you now have the knowledge to build the ultimate gate — the Universe Stargate. It opens paths to far reaches of the galaxy."]
	quest.A1B2C3D4E5F60001.title: "Universe Stargate"
	quest.A1B2C3D4E5F60010.quest_desc: ["Netu is a volcanic world of fire and basalt. Rich in Osmium and dangerous enemies — tread carefully."]
	quest.A1B2C3D4E5F60010.title: "Through Fire — Netu"
	quest.A1B2C3D4E5F60020.quest_desc: ["Niflheim is a frozen world of snow and ice. Hidden beneath its surface lies Trinium, an incredibly strong lightweight metal."]
	quest.A1B2C3D4E5F60020.title: "Into the Frost — Niflheim"
	quest.A1B2C3D4E5F60030.quest_desc: ["Oannes is a vast ocean world. Its depths conceal Naquadria ore — an unstable isotope of Naquadah that must be liquefied before use."]
	quest.A1B2C3D4E5F60030.title: "Below the Waves — Oannes"
	quest.A1B2C3D4E5F60040.quest_desc: ["Mine Trinium ore in Niflheim. Smelt the raw ore into ingots, then alloy it with Naquadah for the ultimate lightweight material."]
	quest.A1B2C3D4E5F60040.title: "Raw Trinium"
	quest.A1B2C3D4E5F60050.quest_desc: ["Naquadria is a rare, unstable isotope of Naquadah found only in Oannes. Unlike Naquadah, it exists as a solid but must be liquefied in a Chemical Reactor for advanced use."]
	quest.A1B2C3D4E5F60050.title: "Naquadria"
	quest.A1B2C3D4E5F60060.quest_desc: ["Combine Trinium Ingots with Naquadah and Naquadah Alloy to create Trinium Alloy — the material of choice for advanced Stargate equipment including the Trinium Iris."]
	quest.A1B2C3D4E5F60060.title: "Trinium Alloy"
