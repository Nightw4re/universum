{
  "sea_level": 63,
  "disable_mob_generation": false,
  "aquifers_enabled": false,
  "ore_veins_enabled": false,
  "legacy_random_source": false,

  "default_block": { "Name": "minecraft:stone" },
  "default_fluid": { "Name": "minecraft:water" },

  "noise": {
    "min_y": 0,
    "height": 384,
    "size_horizontal": 1,
    "size_vertical": 2
  },

  "noise_router": {
    "barrier": 0,
    "fluid_level_floodedness": 0,
    "fluid_level_spread": 0,
    "lava": 1,
    "temperature": 0,
    "vegetation": 0,
    "continents": 1,
    "erosion": 0,
    "depth": 1,
    "ridges": 0,

    "initial_density_without_jaggedness": {
      "type": "minecraft:y_clamped_gradient",
      "from_y": 0,
      "to_y": 64,
      "from_value": 1,
      "to_value": -1
    },

    "final_density": {
      "type": "minecraft:add",
      "argument1": {
        "type": "minecraft:y_clamped_gradient",
        "from_y": 0,
        "to_y": 64,
        "from_value": 1,
        "to_value": -1
      },
      "argument2": {
        "type": "minecraft:mul",
        "argument1": {
          "type": "minecraft:noise",
          "noise": "minecraft:surface",
          "xz_scale": 1,
          "y_scale": 1
        },
        "argument2": 0.12
      }
    },

    "vein_toggle": 0,
    "vein_ridged": 0,
    "vein_gap": 0
  },

  "spawn_target": [],
  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:vertical_gradient",
          "random_name": "minecraft:bedrock_floor",
          "true_at_and_below": { "absolute": 0 },
          "false_at_and_above": { "absolute": 2 }
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:bedrock" }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:vertical_gradient",
          "random_name": "minecraft:stone",
          "true_at_and_below": { "absolute": 0 },
          "false_at_and_above": { "absolute": 32 }
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:stone" }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:noise_threshold",
          "noise": "minecraft:surface",
          "min_threshold": 0.66,
          "max_threshold": 1.0
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": { "Name": "minecraft:sand" }
        }
      },
      {
        "type": "minecraft:block",
        "result_state": { "Name": "minecraft:sandstone" }
      }
    ]
  }
}
